# AG2 Multi-Agent Configuration
# 复制此文件为 .env 并填入你的 API 密钥

# ============================================================
# OpenAI 兼容 API（推荐使用硅基流动，国内可直接访问）
# 注册地址: https://siliconflow.cn
# ============================================================

# API 密钥（必填）
OPENAI_API_KEY=your-api-key-here

# API 基础地址（硅基流动用户必填）
# 硅基流动: https://api.siliconflow.cn/v1
# 标准 OpenAI: 留空或填写 https://api.openai.com/v1
OPENAI_API_BASE=https://api.siliconflow.cn/v1

# ============================================================
# 可选配置
# ============================================================

# Anthropic (Claude) - 仅当不使用 OpenAI 兼容 API 时
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here

# AG2 配置
AG2_CONFIG_LIST=oai_config_list.json
